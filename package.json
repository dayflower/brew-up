{
  "name": "brew-up",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub Action to update Homebrew tap files from release assets",
  "main": "lib/main.js",
  "scripts": {
    "check": "npm run lint && npm run test",
    "build": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
