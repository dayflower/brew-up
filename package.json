{
  "name": "brew-up",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GitHub Action to update Homebrew tap files from release assets",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "check": "biome check src test",
    "fix": "biome check --write src test",
    "test": "vitest run",
    "release:prep": "./scripts/release-prep.sh",
    "release:preflight": "./scripts/release.sh preflight",
    "release:tag": "./scripts/release.sh tag",
    "release:tag:push": "./scripts/release.sh tag --push",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "npm run hooks:install"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@types/mustache": "^4.2.6",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^24.13.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
